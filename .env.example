# ─── pipeline-forge environment variables ────────────────────────────────────
# Copy this file to .env and fill in values for local development.
# NEVER commit .env — it is in .gitignore.
# All variables here are safe defaults for local dev only.

# ─── users-api ───────────────────────────────────────────────────────────────
USERS_API_PORT=3001
USERS_API_NODE_ENV=development
USERS_API_CORS_ORIGIN=*

# ─── orders-api ──────────────────────────────────────────────────────────────
ORDERS_API_PORT=3002
ORDERS_API_NODE_ENV=development
ORDERS_API_CORS_ORIGIN=*

# URL used by orders-api to call users-api.
# In Docker Compose this is the service name. Locally it's localhost.
USERS_API_URL=http://localhost:3001

# ─── Pact Broker ─────────────────────────────────────────────────────────────
PACT_BROKER_URL=http://localhost:9292
PACT_BROKER_USERNAME=pact_user
PACT_BROKER_PASSWORD=pact_password

# Used by CI to publish pact results — set in GitHub Actions secrets
# PACT_BROKER_TOKEN=           # only needed if using PactFlow (Stage 02 optional)

# ─── GitHub Actions / CI ─────────────────────────────────────────────────────
# These are set automatically in GitHub Actions — listed here for documentation.
# GITHUB_TOKEN=                # auto-provided by GitHub Actions
# GH_TOKEN=                    # alias used by semantic-release if GITHUB_TOKEN is unavailable

# ─── Docker / GHCR ───────────────────────────────────────────────────────────
# Set in GitHub Actions secrets for image push (Stage 02+)
# GHCR_USERNAME=               # your GitHub username
# GHCR_TOKEN=                  # GitHub PAT with packages:write scope
